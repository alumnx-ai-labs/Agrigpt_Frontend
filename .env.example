# =============================================================
# AgriGPT Frontend — Environment Variables
# Copy this file to .env and fill in your values.
# .env is gitignored and will never be committed.
# =============================================================

# Agent backend — receives user queries, calls RAG service internally
# Example: https://agrigpt-agent-backend.onrender.com
VITE_AGENT_URL=your_agent_backend_url

# RAG service — handles document retrieval and image queries
# Example: https://agrigpt-rag-service.onrender.com
VITE_RAG_SERVICE_URL=your_rag_service_url

# Computer Vision backend — handles drone video analysis (optional)
VITE_CV_URL=your_cv_service_url

# Speech service — handles speech-to-text and translation (optional)
VITE_SPEECH_URL=your_speech_service_url

# Environment identifier (development | production)
VITE_ENVIRONMENT=development
