{
  "routes": [
    {
      "src": "/api/agent/(.*)",
      "dest": "https://agrigpt-agent-backend.onrender.com/$1"
    },
    {
      "src": "/api/rag/(.*)",
      "dest": "https://agrigpt-rag-service.onrender.com/$1"
    },
    {
      "src": "/api/cv/(.*)",
      "dest": "https://newapi.alumnx.com/agrigpt/cv/$1"
    },
    {
      "src": "/api/speech/(.*)",
      "dest": "https://newapi.alumnx.com/agrigpt/speech/$1"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
